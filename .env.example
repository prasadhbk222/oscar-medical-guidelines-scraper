# Copy to .env and fill in. Do NOT commit .env.
OPENAI_API_KEY=sk-proj-your-key-here

# Async URL used by the backend/pipeline (asyncpg driver).
# Host is localhost when running the app on the host machine against the Docker Postgres.
DATABASE_URL=postgresql+asyncpg://oscar:oscar@localhost:5435/oscar

OPENAI_MODEL=gpt-4o-mini
